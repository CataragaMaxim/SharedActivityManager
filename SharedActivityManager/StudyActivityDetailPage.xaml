<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:media="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui.MediaElement"
             x:Class="SharedActivityManager.StudyActivityDetailPage"
             Title="Study Activity">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Titlu -->
            <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold" TextColor="#2196F3"/>
            <Label x:Name="DescriptionLabel" FontSize="14" TextColor="#666666"/>

            <!-- Video Player -->
            <Border StrokeShape="RoundRectangle 15" BackgroundColor="#000" Padding="0">
                <media:MediaElement x:Name="VideoPlayer" 
                                    HeightRequest="200"
                                    ShouldAutoPlay="False"
                                    ShouldShowPlaybackControls="True"/>
            </Border>

            <!-- URL Entry -->
            <Entry x:Name="UrlEntry" 
                   Placeholder="Enter YouTube URL or video link"
                   Text="{Binding VideoUrl}"/>
            <Button Text="Load Video" 
                    Clicked="OnLoadVideoClicked"
                    BackgroundColor="#2196F3" 
                    TextColor="White"
                    CornerRadius="15"/>

            <!-- Video Progress -->
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="#F0F8FF" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📊 Video Progress" FontAttributes="Bold"/>
                    <ProgressBar x:Name="VideoProgressBar" Progress="0" HeightRequest="10"/>
                    <Label x:Name="VideoProgressLabel" Text="0%" FontSize="14" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Notes -->
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="#FFF8E1" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📝 Notes" FontAttributes="Bold"/>
                    <Editor x:Name="NotesEditor" 
                            Placeholder="Take notes here..."
                            HeightRequest="100"/>
                    <Button Text="Save Note" 
                            Clicked="OnSaveNoteClicked"
                            BackgroundColor="#FF9800" 
                            TextColor="White"
                            CornerRadius="15"/>
                </VerticalStackLayout>
            </Border>

            <!-- Quiz Section -->
            <Border x:Name="QuizSection" 
                    StrokeShape="RoundRectangle 10" 
                    BackgroundColor="#E8F5E9" 
                    Padding="15"
                    IsVisible="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="❓ Quiz" FontAttributes="Bold" FontSize="16"/>
                    <Label x:Name="QuizQuestionLabel" Text="" FontSize="14"/>
                    <CollectionView x:Name="QuizOptionsView" HeightRequest="150"
                                    SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Content="{Binding}" GroupName="QuizOption"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Button Text="Submit Answer" 
                            Clicked="OnSubmitAnswerClicked"
                            BackgroundColor="#4CAF50" 
                            TextColor="White"
                            CornerRadius="15"/>
                    <Label x:Name="QuizScoreLabel" Text="Score: 0%" FontSize="14" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Complete Button -->
            <Button Text="✓ Mark as Completed" 
                    Clicked="OnCompleteClicked"
                    BackgroundColor="#4CAF50" 
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="50"
                    Margin="0,20"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>