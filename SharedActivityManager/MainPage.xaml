<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SharedActivityManager.ViewModels"
             xmlns:models="clr-namespace:SharedActivityManager.Models"
             x:Class="SharedActivityManager.MainPage"
             x:DataType="viewmodels:MainViewModel"
             Title="Activity List">

    <Grid RowDefinitions="Auto,*">

        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="15">
            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">
                <Label Grid.Column="0" 
               Text="Activity List"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="#2196F3"
               VerticalOptions="Center"/>

                <!-- Buton Shared Activities -->
                <Button Grid.Column="1"
                Text="👥 Shared"
                BackgroundColor="#9C27B0"
                TextColor="White"
                CornerRadius="8"
                Padding="15,10"
                Clicked="OnSharedActivitiesClicked"/>

                <!-- Buton Settings -->
                <Button Grid.Column="2"
                Text="⚙️"
                BackgroundColor="#607D8B"
                TextColor="White"
                CornerRadius="8"
                WidthRequest="50"
                Clicked="OnSettingsClicked"/>
            </Grid>

            <!-- Buton Create New Activity -->
            <Button Text="+ Create New Activity"
            Clicked="OnModalOpen"
            BackgroundColor="#4CAF50"
            TextColor="White"
            CornerRadius="8"
            HeightRequest="50"/>
        </VerticalStackLayout>

        <!-- CollectionView direct în Grid, fără Grid în plus -->
        <CollectionView Grid.Row="1"
               ItemsSource="{Binding Activities}"
               EmptyView="No activities yet. Create your first activity!"
               VerticalOptions="FillAndExpand"
               SelectionMode="Single"
               SelectionChanged="OnActivitySelected">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Activity">
                    <Border Stroke="#E0E0E0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="15"
                            Margin="5">

                        <Grid ColumnDefinitions="*, Auto">

                            <VerticalStackLayout Grid.Column="0" Spacing="8">
                                <Label Text="{Binding Title}" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       TextColor="#333333"/>

                                <Label Text="{Binding Desc}" 
                                       FontSize="14" 
                                       TextColor="#666666"
                                       IsVisible="{Binding Desc, Converter={StaticResource StringNotNullOrEmpty}}"/>

                                <HorizontalStackLayout Spacing="15">
                                    <Label Text="{Binding TypeId}" 
                                           FontSize="12" 
                                           TextColor="#2196F3"/>
                                    <Label Text="{Binding StartDate, StringFormat='{0:dd.MM.yyyy}'}" 
                                           FontSize="12" 
                                           TextColor="#FF9800"/>
                                    <Label Text="{Binding StartTime, StringFormat='{0:HH:mm}'}" 
                                           FontSize="12" 
                                           TextColor="#4CAF50"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <ImageButton Grid.Column="1"
                                        Source="check.png"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=ToggleCompleteCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="30"
                                        WidthRequest="30"
                                        BackgroundColor="Transparent"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>