<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SharedActivityManager.ViewModels"
             xmlns:models="clr-namespace:SharedActivityManager.Models"
             x:Class="SharedActivityManager.MainPage"
             Title="Activity List">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ========== BARA DE TOOLS ========== -->
        <HorizontalStackLayout Grid.Row="0" 
                               Padding="15,10" 
                               Spacing="8"
                               BackgroundColor="#F5F5F5">

            <Label Text="📋 Activities"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#2196F3"
                   VerticalOptions="Center"/>

            <!-- Buton Meniu simplu -->
            <Button Text="☰ Menu"
                    Clicked="OnMenuClicked"
                    BackgroundColor="#673AB7"
                    TextColor="White"
                    CornerRadius="8"
                    Padding="15,8"
                    HeightRequest="35"/>

            <!-- Sortare -->
            <Label Text="Sort:"
                   FontSize="12"
                   VerticalOptions="Center"
                   Margin="10,0,0,0"/>

            <Picker Title="Sort by..."
                    ItemsSource="{Binding AvailableSortStrategies}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedSortStrategy}"
                    SelectedIndexChanged="OnSortStrategyChanged"
                    WidthRequest="100"
                    HeightRequest="35"/>

            <Button Text="🔼"
                    Command="{Binding ToggleSortOrderCommand}"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="8"
                    WidthRequest="35"
                    HeightRequest="35"/>

            <Button Text="↩️"
                    Command="{Binding UndoCommand}"
                    IsEnabled="{Binding CanUndo}"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="8"
                    WidthRequest="35"
                    HeightRequest="35"/>

            <Button Text="↪️"
                    Command="{Binding RedoCommand}"
                    IsEnabled="{Binding CanRedo}"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="8"
                    WidthRequest="35"
                    HeightRequest="35"/>

            <Button Text="👥"
                    Clicked="OnSharedActivitiesClicked"
                    BackgroundColor="#9C27B0"
                    TextColor="White"
                    CornerRadius="8"
                    WidthRequest="35"
                    HeightRequest="35"/>

            <Button Text="⚙️"
                    Clicked="OnSettingsClicked"
                    BackgroundColor="#607D8B"
                    TextColor="White"
                    CornerRadius="8"
                    WidthRequest="35"
                    HeightRequest="35"/>

        </HorizontalStackLayout>

        <!-- ========== BUTON CREARE ACTIVITATE ========== -->
        <Button Grid.Row="1"
                Text="+ Create New Activity"
                Clicked="OnModalOpen"
                BackgroundColor="#4CAF50"
                TextColor="White"
                CornerRadius="8"
                HeightRequest="45"
                Margin="15,10"/>

        <!-- ========== LISTA ACTIVITĂȚILOR ========== -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Activities}"
                        EmptyView="No activities yet. Create your first activity!"
                        VerticalOptions="FillAndExpand"
                        SelectionMode="Single"
                        SelectionChanged="OnActivitySelected">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Activity">
                    <Border Stroke="#E0E0E0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="15"
                            Margin="10,5">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="8">
                                <Label Text="{Binding Title}" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="#333333"/>
                                <Label Text="{Binding Desc}" 
                                       FontSize="13" 
                                       TextColor="#666666"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"
                                       IsVisible="{Binding Desc, Converter={StaticResource StringNotNullOrEmpty}}"/>
                                <HorizontalStackLayout Spacing="15">
                                    <Label Text="{Binding TypeId}" 
                                           FontSize="11" 
                                           TextColor="#2196F3"/>
                                    <Label Text="{Binding StartDate, StringFormat='{0:dd.MM.yyyy}'}" 
                                           FontSize="11" 
                                           TextColor="#FF9800"/>
                                    <Label Text="{Binding StartTime, StringFormat='{0:HH:mm}'}" 
                                           FontSize="11" 
                                           TextColor="#4CAF50"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="✓"
                                    BackgroundColor="{Binding IsCompleted, Converter={StaticResource BoolToColorConverter}}"
                                    TextColor="White"
                                    CornerRadius="15"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=ToggleCompleteCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ========== HISTORY BROWSER POPUP ========== -->
        <Frame Grid.RowSpan="3"
               IsVisible="{Binding ShowHistoryBrowser}"
               BackgroundColor="White"
               CornerRadius="15"
               Padding="15"
               Margin="40"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               WidthRequest="350"
               HeightRequest="450"
               ZIndex="100">

            <VerticalStackLayout Spacing="10">
                <Label Text="📜 History Browser"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#673AB7"
                       HorizontalOptions="Center"/>

                <Label Text="Click on any snapshot to restore that state"
                       FontSize="12"
                       TextColor="#666666"
                       HorizontalOptions="Center"/>

                <ScrollView HeightRequest="300">
                    <CollectionView ItemsSource="{Binding HistorySnapshots}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnSnapshotSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#E0E0E0"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="10"
                                        Margin="5">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Name}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#333333"/>
                                        <Label Text="{Binding Description}"
                                               FontSize="11"
                                               TextColor="#666666"/>
                                        <Label Text="{Binding ActivityCount, StringFormat='📊 {0} activities'}"
                                               FontSize="11"
                                               TextColor="#999999"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>

                <Button Text="Close"
                        Command="{Binding ToggleHistoryBrowserCommand}"
                        BackgroundColor="#9E9E9E"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="40"/>

                <Button Text="Clear History"
                        Command="{Binding ClearHistoryCommand}"
                        BackgroundColor="#F44336"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="40"/>
            </VerticalStackLayout>
        </Frame>

    </Grid>
</ContentPage>